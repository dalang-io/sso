# ============================================================================
# Dalang SSO — configuration
# Copy to `.env` and adjust. `.env` is git-ignored and never committed.
# ============================================================================

# --- Server ---
# Address the HTTP server binds to. Use 0.0.0.0 in containers/production.
SSO_BIND_ADDR=127.0.0.1:8080
# Public origin of this SSO instance. Used to build issuer + absolute URLs.
# Must match what clients configure as their auth endpoint.
SSO_PUBLIC_URL=http://localhost:8080

# --- Database ---
# Default: embedded SQLite (zero external dependency).
#   sqlite://data/sso.db
# The scheme selects the driver at runtime (sqlx::Any):
#   postgres://user:pass@host:5432/sso
#   mysql://user:pass@host:3306/sso        # also MariaDB
# Oracle / MSSQL are on the roadmap (feature-gated drivers, see docs/DATABASE.md).
DATABASE_URL=sqlite://data/sso.db?mode=rwc
# Max pooled DB connections per server instance (tune per node for scale).
DATABASE_MAX_CONNECTIONS=32

# --- Cryptographic secrets (GENERATE YOUR OWN — do not ship these) ---
# 32+ byte random string used to sign admin + end-user session cookies.
# REQUIRED in production: the server refuses to start with this placeholder (or
# the built-in dev default) when bound to a non-loopback address.
#   openssl rand -hex 32
SSO_SESSION_SECRET=CHANGE_ME_openssl_rand_hex_32
# Session cookies carry the Secure attribute by default (browser sends them only
# over HTTPS). Set to false ONLY for local plain-HTTP development.
SSO_COOKIE_SECURE=true
# Private RSA key (PEM) used to sign OAuth id_tokens / access tokens (RS256).
# If unset, an ephemeral key is generated on boot (dev only — tokens die on restart).
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem
SSO_JWT_PRIVATE_KEY_PATH=

# Token signing algorithm: `rs256` (default, max interop) or `ml-dsa-65`
# (post-quantum, FIPS 204). See docs/PQC.md.
SSO_TOKEN_SIGNING_ALG=rs256

# --- Token lifetimes (seconds) ---
SSO_ACCESS_TOKEN_TTL=3600
SSO_REFRESH_TOKEN_TTL=2592000
SSO_AUTH_CODE_TTL=600

# --- Branding (all assets served locally — airgap safe) ---
# Shown in the header and browser tab title.
SSO_BRAND_TITLE=Dalang SSO
# Optional: absolute path to a custom logo/icon file (png/webp/svg/jpg). If unset,
# the bundled dalang.io logo is used. Served at /assets/logo.
SSO_LOGO_PATH=
# Optional: absolute path to a custom favicon file (ico/png/webp/svg). If unset,
# the bundled logo is used. Served at /assets/favicon.
SSO_FAVICON_PATH=

# --- First-run onboarding ---
# There is no default admin. On first start, open <SSO_PUBLIC_URL>/setup in a
# browser to create the super admin account (one-time). Once an admin exists,
# /setup is disabled automatically.

# --- Logging ---
# error | warn | info | debug | trace
RUST_LOG=info,sso_server=debug
